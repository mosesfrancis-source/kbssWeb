rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isTeacher() {
      return isAuthenticated() && request.auth.token.role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && request.auth.token.role == 'student';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdminOrTeacher() {
      return isAdmin() || isTeacher();
    }

    // ─── /users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      // A user may create their own document on registration (uid must match)
      allow create: if isOwner(uid) || isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /students ──────────────────────────────────────────────────────────────
    match /students/{uid} {
      allow read: if isOwner(uid) || isTeacher() || isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /teachers ──────────────────────────────────────────────────────────────
    match /teachers/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /classes ───────────────────────────────────────────────────────────────
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── /subjects ──────────────────────────────────────────────────────────────
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── /results ───────────────────────────────────────────────────────────────
    match /results/{resultId} {
      allow read: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || isTeacher();
      allow create: if isAdminOrTeacher();
      allow update: if isAdminOrTeacher();
      allow delete: if isAdmin();
    }

    // ─── /attendance ────────────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      allow read: if isAdmin()
        || (isStudent() && resource.data.studentId == request.auth.uid)
        || isTeacher();
      allow create: if isAdminOrTeacher();
      allow update: if isAdminOrTeacher();
      allow delete: if isAdmin();
    }

    // ─── /assignments ───────────────────────────────────────────────────────────
    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrTeacher();
      allow update: if isAdminOrTeacher();
      allow delete: if isAdminOrTeacher();
    }

    // ─── /submissions ───────────────────────────────────────────────────────────
    match /submissions/{submissionId} {
      allow read: if isAdmin()
        || isTeacher()
        || (isStudent() && resource.data.studentId == request.auth.uid);
      allow create: if isAuthenticated()
        && (isStudent() || isAdmin());
      allow update: if isAdminOrTeacher()
        || (isStudent() && resource.data.studentId == request.auth.uid
            && resource.data.status == 'pending');
      allow delete: if isAdmin();
    }

    // ─── /announcements ─────────────────────────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrTeacher();
      allow update: if isAdminOrTeacher();
      allow delete: if isAdmin();
    }

    // ─── /events ────────────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /admissions ────────────────────────────────────────────────────────────
    match /admissions/{applicationId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /gallery ───────────────────────────────────────────────────────────────
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── /resources ─────────────────────────────────────────────────────────────
    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create: if isAdminOrTeacher();
      allow update: if isAdminOrTeacher();
      allow delete: if isAdminOrTeacher();
    }

    // ─── /notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAdminOrTeacher() || isAdmin();
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ─── /settings ──────────────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
