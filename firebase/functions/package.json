    "@typescript-eslint/parser": "^7.1.1",
    "eslint": "^8.57.0",
    "eslint-config-google": "^0.14.0",
    "typescript": "^5.3.3",
    "@types/nodemailer": "^6.4.14",
    "@types/jspdf": "^2.0.0"
  },
